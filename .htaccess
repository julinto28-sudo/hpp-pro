<IfModule mod_rewrite.c>
  RewriteEngine On
  
  # 1. Route API requests starting with /api/ directly to api.php
  # Example: domain.com/api/auth/login -> domain.com/api.php?route=auth/login
  RewriteRule ^api/(.*)$ api.php?route=$1 [QSA,L]
  
  # 2. Standard SPA Fallback routing for React
  # If the requested file or folder does not exist, serve index.html
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^ index.html [L]
</IfModule>

# Block external access to database PHP file for absolute security
<Files "db_store.json.php">
  Order Allow,Deny
  Deny from all
</Files>
